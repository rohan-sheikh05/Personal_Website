# Copy this file to .env.local for local development.
# For production, add the same keys/values in Cloudflare Pages:
# Dashboard -> your project -> Settings -> Environment variables.
#
# All values come from: Firebase Console -> Project settings -> General
# -> scroll to "Your apps" -> select your web app -> "SDK setup and configuration"

REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# Cloudinary (free, no credit card required) - used for all file uploads
# in the admin panel (photos, certificates, club logos, CV). Get these from
# cloudinary.com -> Dashboard (cloud name) -> Settings -> Upload -> Upload
# presets -> create one with Signing Mode = Unsigned (preset name).
REACT_APP_CLOUDINARY_CLOUD_NAME=
REACT_APP_CLOUDINARY_UPLOAD_PRESET=
